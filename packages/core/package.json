{
  "name": "@react-ai-form/core",
  "version": "0.2.5",
  "publishConfig": {
    "access": "public"
  },
  "description": "Core utilities for AI-powered React forms — schema extraction, privacy filtering, streaming, caching",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/burhanharoon/react-ai-form.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/burhanharoon/react-ai-form/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/burhanharoon/react-ai-form/issues"
  },
  "keywords": [
    "react",
    "ai",
    "forms",
    "zod",
    "schema",
    "streaming",
    "privacy",
    "llm"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "echo \"no linter yet\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "zod": "^3.23",
    "ai": "^4.0"
  },
  "devDependencies": {
    "zod": "^3.23.0",
    "ai": "^4.0.0"
  },
  "license": "MIT"
}
