{
  "name": "react-ai-form",
  "version": "0.0.0",
  "private": true,
  "description": "React library that enhances forms with AI capabilities",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "check:tree-shake": "node scripts/check-tree-shaking.mjs",
    "check:publish": "pnpm -r --filter='./packages/**' exec publint && pnpm -r --filter='./packages/**' exec attw --pack .",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/burhanharoon/react-ai-form.git"
  },
  "keywords": [
    "react",
    "forms",
    "ai",
    "zod",
    "react-hook-form"
  ],
  "author": "burhanharoon",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/burhanharoon/react-ai-form/issues"
  },
  "homepage": "https://github.com/burhanharoon/react-ai-form#readme",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.11",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "esbuild": "^0.28.0",
    "publint": "^0.3.18",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
