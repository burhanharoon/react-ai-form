{
  "name": "@react-ai-form/react-hook-form",
  "version": "0.2.4",
  "publishConfig": {
    "access": "public"
  },
  "description": "React Hook Form adapter for react-ai-form — connects AI hooks to React Hook Form's setValue/trigger API",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/burhanharoon/react-ai-form.git",
    "directory": "packages/react-hook-form"
  },
  "homepage": "https://github.com/burhanharoon/react-ai-form/tree/main/packages/react-hook-form#readme",
  "bugs": {
    "url": "https://github.com/burhanharoon/react-ai-form/issues"
  },
  "keywords": [
    "react",
    "ai",
    "forms",
    "react-hook-form",
    "adapter"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "echo \"no linter yet\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@react-ai-form/react": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^4.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.50.0",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ai": "^4.0.0",
    "jsdom": "^29.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.50.0",
    "zod": "^3.23.0"
  },
  "license": "MIT"
}
