{
  "name": "@react-ai-form/react",
  "version": "0.2.4",
  "publishConfig": {
    "access": "public"
  },
  "description": "React hooks and components for AI-powered forms — suggestions, form fill, ghost text, accessible UI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/burhanharoon/react-ai-form.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/burhanharoon/react-ai-form/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/burhanharoon/react-ai-form/issues"
  },
  "keywords": [
    "react",
    "ai",
    "forms",
    "hooks",
    "suggestions",
    "ghost-text",
    "accessibility",
    "streaming"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node ../../scripts/add-use-client.mjs dist/index.js dist/index.cjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "echo \"no linter yet\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@react-ai-form/core": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^4.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ai": "^4.0.0",
    "jsdom": "^29.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.0"
  },
  "license": "MIT"
}
